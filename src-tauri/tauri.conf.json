{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD-Vi",
  "version": "0.1.0",
  "identifier": "com.ansad.md-vi",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MD-Vi",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "MD-Vi",
        "description": "Markdown File"
      }
    ]
  }
}
